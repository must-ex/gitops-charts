{
  "$schema": "http://json-schema.org/draft-07/schema",
  "type": "object",
  "required": ["global"],
  "properties": {
    "global": {
      "type": "object",
      "required": ["esoSecretName", "awsRegion"],
      "properties": {
        "ecrRegistry":       { "type": "string" },
        "esoSecretName":     { "type": "string", "minLength": 1 },
        "esoRoleArn":        { "type": "string" },
        "awsRegion":         { "type": "string", "minLength": 1 },
        "domain":            { "type": "string" },
        "acmCertificateArn": { "type": "string" }
      }
    },
    "services": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["image", "resources"],
        "properties": {
          "enabled":      { "type": "boolean" },
          "replicaCount": { "type": "integer", "minimum": 0 },
          "containerPort": { "type": "integer" },
          "reloader":     { "type": "boolean" },
          "image": {
            "type": "object",
            "required": ["repository", "tag"],
            "properties": {
              "repository": { "type": "string", "minLength": 1 },
              "tag":        { "type": "string", "minLength": 1 }
            }
          },
          "resources": {
            "type": "object",
            "required": ["requests", "limits"],
            "properties": {
              "requests": {
                "type": "object",
                "required": ["cpu", "memory"],
                "properties": {
                  "cpu":    { "type": "string" },
                  "memory": { "type": "string" }
                }
              },
              "limits": {
                "type": "object",
                "required": ["cpu", "memory"],
                "properties": {
                  "cpu":    { "type": "string" },
                  "memory": { "type": "string" }
                }
              }
            }
          },
          "service": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "port":    { "type": "integer" },
              "type":    { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] }
            }
          },
          "hpa": {
            "type": "object",
            "properties": {
              "enabled":                        { "type": "boolean" },
              "minReplicas":                    { "type": "integer", "minimum": 1 },
              "maxReplicas":                    { "type": "integer", "minimum": 1 },
              "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
            }
          }
        }
      }
    }
  }
}
